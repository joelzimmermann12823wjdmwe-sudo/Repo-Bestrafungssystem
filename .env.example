DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_guild_id_here
PUNISHMENT_ROLE_ID=your_punishment_role_id_here
ADMIN_ROLE_IDS=admin_role_id_1,admin_role_id_2
WEB_HOST=0.0.0.0
PORT=8080
DATA_DIR=.
WEB_USERNAME=admin
WEB_PASSWORD=your_secure_password_here

# Google Drive (optional - fuer Cloud Upload)
# Erstelle ein Service Account: https://console.cloud.google.com/apis/credentials
# Teile den Google Drive Folder mit der Service Account Email
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=optional_parent_folder_id
