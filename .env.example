DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_guild_id_here
PUNISHMENT_ROLE_ID=your_punishment_role_id_here
ADMIN_ROLE_IDS=admin_role_id_1,admin_role_id_2
WEB_HOST=0.0.0.0
PORT=8080
DATA_DIR=.

# Discord OAuth2 (Pflicht - fuer Login auf der Website)
# Erstelle eine OAuth2 App im Discord Developer Portal:
# 1. Gehe zu https://discord.com/developers/applications
# 2. Waehle deine App (oder erstelle eine)
# 3. Unter OAuth2: Client ID + Client Secret kopieren
# 4. Redirect URI eintragen: https://deine-app.onrender.com/api/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Google Drive (optional - fuer Cloud Upload)
# Erstelle ein Service Account: https://console.cloud.google.com/apis/credentials
# Teile den Google Drive Folder mit der Service Account Email
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=optional_parent_folder_id
